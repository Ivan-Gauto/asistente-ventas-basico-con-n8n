# Copia este archivo como .env.local y rellena los valores reales
# ⚠️ NUNCA subas .env.local a GitHub

# API Key de n8n (se obtiene desde n8n > Settings > API Keys)
VITE_N8N_API_KEY=tu_api_key_de_n8n_aqui

# URL del webhook del agente n8n
# En local usa: /webhook-test/mi-chat-bot
# En producción (Vercel) usa la URL pública de tu n8n cloud: https://tu-instancia.n8n.cloud/webhook/mi-chat-bot
VITE_N8N_WEBHOOK_URL=/webhook-test/mi-chat-bot
